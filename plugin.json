{
  "Id": "ea521bb8-4414-44be-bf42-4b2851ae32ad",
  "TriggerKeywords": ["ri"],
  "Name": "i18n:plugin_name",
  "Description": "i18n:plugin_description",
  "Author": "qianlifeng",
  "Version": "0.0.1",
  "MinWoxVersion": "2.0.0",
  "Runtime": "nodejs",
  "Website": "https://github.com/qianlifeng/Wox.Plugin.Rimage",
  "Entry": "index.js",
  "Icon": "relative:images/app.svg",
  "SupportedOS": ["windows", "linux", "darwin"],
  "Features": [
    {
      "Name": "querySelection"
    }
  ],
  "SettingDefinitions": [
    {
      "Type": "head",
      "Value": {
        "Content": "i18n:settings_common",
        "Tooltip": ""
      }
    },
    {
      "Type": "checkbox",
      "Value": {
        "Key": "replace_original",
        "Label": "i18n:setting_replace_original",
        "DefaultValue": "true",
        "Tooltip": "i18n:setting_replace_original_tooltip"
      }
    },
    {
      "Type": "checkbox",
      "Value": {
        "Key": "strip_metadata",
        "Label": "i18n:setting_strip_metadata",
        "DefaultValue": "false",
        "Tooltip": "i18n:setting_strip_metadata_tooltip"
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "threads",
        "Label": "i18n:setting_threads",
        "DefaultValue": "",
        "Tooltip": "i18n:setting_threads_tooltip",
        "MaxLines": 1,
        "Validators": []
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "resize",
        "Label": "i18n:setting_resize",
        "DefaultValue": "",
        "Tooltip": "i18n:setting_resize_tooltip",
        "MaxLines": 1,
        "Validators": []
      }
    },
    {
      "Type": "select",
      "Value": {
        "Key": "resize_policy",
        "Label": "i18n:setting_resize_policy",
        "DefaultValue": "default",
        "Tooltip": "i18n:setting_resize_policy_tooltip",
        "IsMulti": false,
        "Options": [
          {
            "Label": "i18n:resize_policy_default",
            "Value": "default"
          },
          {
            "Label": "i18n:resize_policy_downscale",
            "Value": "downscale"
          },
          {
            "Label": "i18n:resize_policy_upscale",
            "Value": "upscale"
          }
        ],
        "Validators": []
      }
    },
    {
      "Type": "head",
      "Value": {
        "Content": "i18n:settings_quality",
        "Tooltip": ""
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "jpeg_quality",
        "Label": "i18n:setting_jpeg_quality",
        "DefaultValue": "75",
        "Tooltip": "i18n:setting_jpeg_quality_tooltip",
        "MaxLines": 1,
        "Suffix": "0-100",
        "Validators": [
          {
            "Type": "is_number",
            "Value": {
              "IsInteger": true,
              "IsFloat": false
            }
          }
        ]
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "png_effort",
        "Label": "i18n:setting_png_effort",
        "DefaultValue": "2",
        "Tooltip": "i18n:setting_png_effort_tooltip",
        "MaxLines": 1,
        "Suffix": "0-6",
        "Validators": [
          {
            "Type": "is_number",
            "Value": {
              "IsInteger": true,
              "IsFloat": false
            }
          }
        ]
      }
    },
    {
      "Type": "checkbox",
      "Value": {
        "Key": "png_interlace",
        "Label": "i18n:setting_png_interlace",
        "DefaultValue": "false",
        "Tooltip": "i18n:setting_png_interlace_tooltip"
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "webp_quality",
        "Label": "i18n:setting_webp_quality",
        "DefaultValue": "75",
        "Tooltip": "i18n:setting_webp_quality_tooltip",
        "MaxLines": 1,
        "Suffix": "0-100",
        "Validators": [
          {
            "Type": "is_number",
            "Value": {
              "IsInteger": true,
              "IsFloat": false
            }
          }
        ]
      }
    },
    {
      "Type": "checkbox",
      "Value": {
        "Key": "webp_lossless",
        "Label": "i18n:setting_webp_lossless",
        "DefaultValue": "false",
        "Tooltip": "i18n:setting_webp_lossless_tooltip"
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "avif_quality",
        "Label": "i18n:setting_avif_quality",
        "DefaultValue": "50",
        "Tooltip": "i18n:setting_avif_quality_tooltip",
        "MaxLines": 1,
        "Suffix": "0-100",
        "Validators": [
          {
            "Type": "is_number",
            "Value": {
              "IsInteger": true,
              "IsFloat": false
            }
          }
        ]
      }
    },
    {
      "Type": "textbox",
      "Value": {
        "Key": "avif_speed",
        "Label": "i18n:setting_avif_speed",
        "DefaultValue": "6",
        "Tooltip": "i18n:setting_avif_speed_tooltip",
        "MaxLines": 1,
        "Suffix": "1-10",
        "Validators": [
          {
            "Type": "is_number",
            "Value": {
              "IsInteger": true,
              "IsFloat": false
            }
          }
        ]
      }
    }
  ],
